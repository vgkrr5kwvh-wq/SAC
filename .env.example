# MySQL or MariaDB connection string used by Prisma.
DATABASE_URL=

# Resend notification delivery.
RESEND_API_KEY=
ENQUIRY_FROM_EMAIL=
ENQUIRY_NOTIFICATION_TO=

# A long, random server-only value used to hash rate-limit identifiers.
RATE_LIMIT_SALT=

# Optional positive integers. Defaults: 15 minutes and 5 submissions.
RATE_LIMIT_WINDOW_MINUTES=
RATE_LIMIT_MAX_SUBMISSIONS=
