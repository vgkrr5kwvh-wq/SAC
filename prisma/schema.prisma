generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Enquiry {
  id                   String             @id @default(cuid()) @db.VarChar(30)
  name                 String             @db.VarChar(120)
  email                String             @db.VarChar(254)
  interest             String?            @db.VarChar(200)
  message              String             @db.Text
  clientHash           String             @db.Char(64)
  notificationStatus   NotificationStatus @default(PENDING)
  notificationFailedAt DateTime?
  createdAt            DateTime           @default(now())

  @@index([clientHash, createdAt])
  @@index([email, createdAt])
}

model PartnerEnquiry {
  id                   String             @id @default(cuid()) @db.VarChar(30)
  partnerType          String             @db.VarChar(50)
  contactName          String             @db.VarChar(120)
  workEmail            String             @db.VarChar(254)
  organisation         String             @db.VarChar(200)
  locations            String             @db.VarChar(255)
  partnershipProposal  String             @db.VarChar(200)
  details              String             @db.Text
  additionalDetails    String?            @db.Text
  clientHash           String             @db.Char(64)
  notificationStatus   NotificationStatus @default(PENDING)
  notificationFailedAt DateTime?
  createdAt            DateTime           @default(now())

  @@index([clientHash, createdAt])
  @@index([workEmail, createdAt])
}

model AdminUser {
  id           String   @id @default(cuid()) @db.VarChar(30)
  email        String   @unique @db.VarChar(191)
  passwordHash String   @db.VarChar(255)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model BlogPost {
  id              String         @id @default(cuid()) @db.VarChar(30)
  title           String         @db.VarChar(200)
  slug            String         @unique @db.VarChar(220)
  excerpt         String?        @db.VarChar(500)
  content         String         @db.LongText
  coverImageUrl   String?        @db.VarChar(2048)
  status          BlogPostStatus @default(DRAFT)
  featured        Boolean        @default(false)
  seoTitle        String?        @db.VarChar(70)
  metaDescription String?        @db.VarChar(160)
  publishedAt     DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  categories      Category[]

  @@index([status, publishedAt])
  @@index([createdAt])
  @@index([featured])
}

model Category {
  id          String     @id @default(cuid()) @db.VarChar(30)
  name        String     @db.VarChar(120)
  slug        String     @unique @db.VarChar(160)
  description String?    @db.VarChar(500)
  isActive    Boolean    @default(true)
  sortOrder   Int        @default(0)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  posts       BlogPost[]

  @@index([isActive, sortOrder])
}

enum NotificationStatus {
  PENDING
  SENT
  FAILED
}

enum BlogPostStatus {
  DRAFT
  PUBLISHED
}
